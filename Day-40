#include <stdio.h>

int main() {
    int n, i;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];

    printf("Enter elements:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    int maxSum = arr[0];     
    int currentSum = arr[0]; 

    for(i = 1; i < n; i++) {

        
        if(arr[i] > currentSum + arr[i])
            currentSum = arr[i];
        else
            currentSum = currentSum + arr[i];

        
        if(currentSum > maxSum)
            maxSum = currentSum;
    }

    printf("Maximum Subarray Sum = %d\n", maxSum);

    return 0;
}
